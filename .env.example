# === FarmacoVigía — variables de entorno ===
# Copia este archivo a .env y rellena con valores reales.

# === Infraestructura compartida ===
# ClickHouse Cloud (HTTP interface). Persona B crea la instancia y comparte la URL.
# Puede llevar credenciales en la URL: https://user:pass@HOST.clickhouse.cloud:8443
# o como query params: https://HOST.clickhouse.cloud:8443/?user=default&password=XXXX
CLICKHOUSE_URL=
# Alternativa: credenciales separadas (si no las metes en la URL)
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=
CLICKHOUSE_DATABASE=default

# === Composio (Slack / Gmail tool calls) — Persona B ===
COMPOSIO_API_KEY=
# Slug del usuario/entidad conectada en Composio (la "connected account")
COMPOSIO_USER_ID=default
# Canal de Slack destino (id o nombre, ej: #alertas o C0XXXXXX) — CANAL ACTIVO
COMPOSIO_SLACK_CHANNEL=
# Destino de Gmail (listo, pendiente de destrabar OAuth de Google en Composio)
COMPOSIO_GMAIL_TO=

# === LLM vía AI Gateway de TrueFoundry (OpenAI-compatible) — Persona A ===
# LLM_BASE_URL debe ser OpenAI-compatible (incluir /v1 si el gateway lo usa)
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=claude-sonnet-4-6
# Prompt del boletín: vive en TrueFoundry (UI: ML Repos -> Prompts). FQN de la versión.
LLM_PROMPT_FQN=chat_prompt:healthy/default/farmawatch-recall-bulletin:1

# === Fuentes de datos (Persona A) ===
# Padrón de pacientes: ruta a un JSON propio [{id, name, drugs[]}, ...].
# Vacío = usa el padrón demo en demo/seed-data/patients.json
PATIENTS_FILE=
# openFDA (no requiere API key para uso básico)
OPENFDA_BASE=https://api.fda.gov
# Opcional: sube el rate limit (240/min y 120k/día). Pídela gratis en https://open.fda.gov/apis/authentication/
OPENFDA_API_KEY=

# === Operación / flags de demo (Plan B) ===
# USE_SEED=1 -> el worker usa el fixture determinista de demo/seed-data (no depende de openFDA en vivo)
USE_SEED=0
# DRY_RUN=true -> postAlert imprime en consola en vez de enviar (default seguro)
# DRY_RUN=false -> envía de verdad vía Composio (Slack/Gmail)
DRY_RUN=true
# WORKER_INTERVAL_SEC=60 -> el worker revisa en bucle cada N segundos (0 o vacío = una sola pasada)
WORKER_INTERVAL_SEC=0
# Puerto del API (Render lo inyecta automáticamente)
PORT=3000
