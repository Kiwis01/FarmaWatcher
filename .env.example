# === Infraestructura compartida ===
# ClickHouse (tablas events + paid_requests). Puede llevar credenciales: https://user:pass@host:8443
CLICKHOUSE_URL=

# === Persona B: rieles de dinero ===
CDP_API_KEY_ID=
CDP_API_KEY_SECRET=
WALLET_ADDRESS=
SENSO_API_KEY=

# === Composio (Slack/Gmail tool calls) ===
COMPOSIO_API_KEY=
COMPOSIO_SLACK_CHANNEL=

# === Twilio WhatsApp (Persona A) ===
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
ALERT_WHATSAPP_TO=

# === AWS ===
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# === Fuentes de datos (Persona A) ===
OPENFDA_BASE=https://api.fda.gov
OPENFDA_API_KEY=
RXNORM_BASE=https://rxnav.nlm.nih.gov/REST

# === LLM via AI Gateway (TrueFoundry emite la virtual key; ver TEAMPLAN) ===
# LLM_BASE_URL debe ser OpenAI-compatible (incluir el prefijo /v1 si el gateway lo usa)
LLM_PROVIDER=truefoundry
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL_BULLETIN=claude-sonnet-4-6
LLM_MODEL_CLASSIFIER=pioneer

# === Worker (Persona A) ===
POLL_INTERVAL_MS=300000
SEED_RECALL=true
PATIENTS_FILE=demo/seed-data/patients.json
SEEDED_RECALL_FILE=demo/seed-data/seeded-recall.json
