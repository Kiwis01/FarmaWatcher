# === FarmacoVigía — variables de entorno (M0, contrato congelado) ===
# Copia este archivo a .env y rellena con valores reales.

# ClickHouse Cloud (HTTP interface). Persona B crea la instancia y comparte la URL.
# Incluye credenciales como query params, p.ej.:
#   https://HOST.clickhouse.cloud:8443/?user=default&password=XXXX
CLICKHOUSE_URL=

# Composio (Slack/Gmail) — Persona B
COMPOSIO_API_KEY=

# LLM vía AI Gateway de TrueFoundry (OpenAI-compatible). Persona B emite la virtual key.
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=claude-sonnet-4-6

# openFDA (no requiere API key para uso básico)
OPENFDA_BASE=https://api.fda.gov
# Opcional: sube el rate limit (240/min y 120k/día). Pídela gratis en https://open.fda.gov/apis/authentication/
OPENFDA_API_KEY=

# --- Flags de demo (Plan B) ---
# USE_SEED=1 -> el worker usa el fixture determinista de demo/seed-data (no depende de openFDA en vivo)
USE_SEED=0
# DRY_RUN=1  -> postAlert imprime en consola en vez de enviar (default seguro hasta cablear Composio)
DRY_RUN=1
# WORKER_INTERVAL_SEC=60 -> el worker revisa en bucle cada N segundos (0 o vacío = una sola pasada)
WORKER_INTERVAL_SEC=0
