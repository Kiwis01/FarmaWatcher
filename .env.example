# === Infraestructura compartida ===
# ClickHouse Cloud. Puede llevar credenciales en la URL: https://user:pass@host:8443
CLICKHOUSE_URL=
# Alternativa: credenciales separadas (si no las metes en la URL)
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=
CLICKHOUSE_DATABASE=default

# === Composio (Slack / Gmail tool calls) — Persona B ===
COMPOSIO_API_KEY=
# Slug del usuario/entidad conectada en Composio (la "connected account")
COMPOSIO_USER_ID=default
# Canal de Slack destino (id o nombre, ej: #alertas o C0XXXXXX) — CANAL ACTIVO
COMPOSIO_SLACK_CHANNEL=
# Destino de Gmail (listo, pendiente de destrabar OAuth de Google en Composio)
COMPOSIO_GMAIL_TO=

# === LLM vía AI Gateway (TrueFoundry emite la virtual key) — Persona A ===
# LLM_BASE_URL debe ser OpenAI-compatible (incluir /v1 si el gateway lo usa)
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=claude-sonnet-4-6

# === Fuentes de datos (Persona A) ===
OPENFDA_BASE=https://api.fda.gov

# === Operación ===
# Si DRY_RUN=true, postAlert imprime en consola en vez de publicar (Plan B en vivo)
DRY_RUN=false
PORT=3000
