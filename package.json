{
  "name": "farmavigia",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "worker": "npm run start -w @farmavigia/worker",
    "dashboard": "npm run start -w @farmavigia/dashboard",
    "dashboard:build": "npm run build -w @farmavigia/dashboard"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
